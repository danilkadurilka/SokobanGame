<Window x:Class="SokobanGame.Views.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SokobanGame.Views"
        mc:Ignorable="d"
        Title="Сокобан - Игра" Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        Background="Purple"
        KeyDown="Window_KeyDown"
        ResizeMode="NoResize"
        Icon="/Images/sokoban.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#6A3E6B" Height="80">
            <Grid Margin="20 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Игрок: " Foreground="White" FontSize="18"/>
                    <TextBlock Text="{Binding PlayerName}" Foreground="#FFD966" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20 0">
                    <TextBlock Text="Ходов: " Foreground="White" FontSize="18"/>
                    <TextBlock Text="{Binding Moves, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFD966" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20 0">
                    <TextBlock Text="Время: " Foreground="White" FontSize="18"/>
                    <TextBlock Text="{Binding CurrentTime, UpdateSourceTrigger=PropertyChanged}" Foreground="#FFD966" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↺ Перезапуск" 
                            Command="{Binding RestartCommand}"
                            Background="#9B4D96"
                            Foreground="White"
                            FontSize="16"
                            Padding="15 8"
                            Margin="5"
                            BorderThickness="0">
                    </Button>

                    <Button Content="🏠 Меню" 
                            Command="{Binding BackToMenuCommand}"
                            Background="#9B4D96"
                            Foreground="White"
                            FontSize="16"
                            Padding="15 8"
                            Margin="5"
                            BorderThickness="0">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#2D1B3D" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#3D2B4D" BorderThickness="0.5">
                                        <Image Source="{Binding TileImage}" 
                                               Width="40" 
                                               Height="40"
                                               Stretch="Uniform"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <Border Grid.Row="2" Background="#6A3E6B" Height="70">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Управление: " Foreground="White" FontSize="14" Margin="10 0"/>
                <TextBlock Text="← ↑ ↓ →" Foreground="#FFD966" FontSize="14" FontWeight="Bold" Margin="5 0"/>
                <TextBlock Text="или" Foreground="White" FontSize="14" Margin="5 0"/>
                <TextBlock Text="W A S D" Foreground="#FFD966" FontSize="14" FontWeight="Bold" Margin="5 0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>