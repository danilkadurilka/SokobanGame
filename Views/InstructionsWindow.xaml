<Window x:Class="SokobanGame.Views.InstructionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SokobanGame.Views"
        mc:Ignorable="d"
        Title="Сокобан - Как играть" Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="Purple"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Icon="/Images/sokoban.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#6A3E6B" Height="80">
            <TextBlock Text="❓ Как играть в Сокобан ❓"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
        <StackPanel Margin="10" Grid.Row="1">
            <Border Background="#4A2B5A" CornerRadius="10" Padding="20" Margin="0 0 0 15">
                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14">
                        <Run Text="🎮 "/><Run Text="Что такое Сокобан?" FontWeight="Bold" FontSize="16"/><LineBreak/>
                        <Run Text="Сокобан (Sokoban) — классическая японская логическая игра-головоломка, созданная в 1981 году."/>
                </TextBlock>
            </Border>
            <Border Background="#4A2B5A" CornerRadius="10" Padding="20" Margin="0 0 0 15">
                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14">
                    <Run Text="🎯 "/><Run Text="Цель игры" FontWeight="Bold" FontSize="16"/><LineBreak/>
                    <Run Text="Переместить все ящики на целевые позиции. Ящики можно только толкать, но не тянуть."/>
                </TextBlock>
            </Border>
            <Border Background="#4A2B5A" CornerRadius="10" Padding="20" Margin="0 0 0 15">
                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14">
                    <Run Text="⌨️ "/><Run Text="Управление" FontWeight="Bold" FontSize="16"/><LineBreak/>
                    <Run Text="• Стрелки (← ↑ ↓ →) или клавиши W A S D для перемещения"/><LineBreak/>
                    <Run Text="• R - перезапуск уровня"/><LineBreak/>
                    <Run Text="• Esc - выход в меню"/>
                </TextBlock>
            </Border>
            <Border Background="#4A2B5A" CornerRadius="10" Padding="20" Margin="0 0 0 15">
                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14">
                        <Run Text="🏆 "/><Run Text="Рекорды" FontWeight="Bold" FontSize="16"/><LineBreak/>
                        <Run Text="Рекорды фиксируются по количеству ходов и времени прохождения."/>
                </TextBlock>
            </Border>
        </StackPanel>
        <Border Grid.Row="2" Background="#6A3E6B" Height="70">
            <Button Content="← Вернуться в меню"
                    Background="#9B4D96"
                    Foreground="White"
                    FontSize="16"
                    Padding="15 8"
                    BorderThickness="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="BackToMenu_Click">
            </Button>
        </Border>
    </Grid>
</Window>
